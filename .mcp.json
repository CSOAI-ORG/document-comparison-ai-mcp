{
  "name": "document-comparison-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 Advanced document comparison with diff highlighting and version tracking.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "compare_documents",
      "description": "Compare two documents and find differences",
      "parameters": {
        "type": "object",
        "properties": {
          "doc1": {
            "type": "string"
          },
          "doc2": {
            "type": "string"
          }
        },
        "required": [
          "doc1",
          "doc2"
        ]
      }
    },
    {
      "name": "compare_versions",
      "description": "Compare two stored document versions",
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string"
          },
          "version1": {
            "type": "integer"
          },
          "version2": {
            "type": "integer"
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "store_document",
      "description": "Store a document for future comparisons",
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          }
        },
        "required": [
          "doc_id",
          "content"
        ]
      }
    },
    {
      "name": "get_document",
      "description": "Get a stored document",
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "list_versions",
      "description": "List all versions of a document",
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string"
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "compute_similarity",
      "description": "Compute similarity score between texts",
      "parameters": {
        "type": "object",
        "properties": {
          "text1": {
            "type": "string"
          },
          "text2": {
            "type": "string"
          }
        },
        "required": [
          "text1",
          "text2"
        ]
      }
    },
    {
      "name": "find_common_terms",
      "description": "Find common and unique terms between documents",
      "parameters": {
        "type": "object",
        "properties": {
          "doc1": {
            "type": "string"
          },
          "doc2": {
            "type": "string"
          }
        },
        "required": [
          "doc1",
          "doc2"
        ]
      }
    },
    {
      "name": "get_comparison_history",
      "description": "Get comparison history",
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "export_diff",
      "description": "Export diff in specified format",
      "parameters": {
        "type": "object",
        "properties": {
          "comparison_id": {
            "type": "string"
          },
          "format": {
            "type": "string"
          }
        },
        "required": [
          "comparison_id"
        ]
      }
    }
  ]
}